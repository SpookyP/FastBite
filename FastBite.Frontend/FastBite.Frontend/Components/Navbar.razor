@using FastBite.Services
@using FastBite.Models
@inject AuthState Auth
@inject CartState Cart
@inject NavigationManager Nav
@implements IDisposable

<header class="sticky top-0 z-40 w-full border-b bg-white/80 backdrop-blur-md shadow-sm">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">

        <a href="/" class="flex items-center gap-2">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-orange-600 text-white">
                🍽️
            </span>
            <span class="text-xl font-bold text-orange-600" style="font-family: Poppins, sans-serif;">
                FastBite
            </span>
        </a>

        <nav class="flex items-center gap-1">
            <a href="/" class="px-3 py-2 rounded-md text-sm font-medium hover:bg-orange-50 transition-colors">Menu</a>

            @if (Auth.IsAuthenticated)
            {
                <a href="/orders" class="px-3 py-2 rounded-md text-sm font-medium hover:bg-orange-50 transition-colors">
                    📦 Orders
                </a>
            }

            <a href="/cart" class="relative px-3 py-2 rounded-md text-sm font-medium hover:bg-orange-50 transition-colors">
                🛒
                @if (Cart.Count > 0)
                {
                    <span class="absolute -right-1 -top-1 flex h-5 w-5 items-center justify-center rounded-full bg-orange-600 text-xs text-white">
                        @Cart.Count
                    </span>
                }
            </a>

            @if (Auth.IsAuthenticated)
            {
                <div class="flex items-center gap-2 ml-2">
                    <span class="text-sm text-gray-600">@Auth.User!.Name</span>
                    <button @onclick="Logout"
                            class="px-3 py-1.5 rounded-md text-sm font-medium border border-gray-200 hover:bg-red-50 hover:text-red-600 transition-colors">
                        Logout
                    </button>
                </div>
            }
            else
            {
                <a href="/login"
                   class="ml-2 px-4 py-1.5 rounded-md text-sm font-medium bg-orange-600 text-white hover:bg-orange-700 transition-colors">
                    Sign in
                </a>
            }
        </nav>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        Auth.OnChange += StateHasChanged;
        Cart.OnChange += StateHasChanged;
    }

    private void Logout()
    {
        Auth.Logout();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Auth.OnChange -= StateHasChanged;
        Cart.OnChange -= StateHasChanged;
    }
}
