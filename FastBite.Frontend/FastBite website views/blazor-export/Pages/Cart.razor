@page "/cart"
@using FastBite.Models
@using FastBite.Services
@inject CartState Cart
@inject AuthState Auth
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Cart — FastBite</PageTitle>

@if (!Cart.Items.Any())
{
    <div class="flex min-h-screen flex-col items-center justify-center gap-4 px-4 text-center">
        <span class="text-7xl">🛒</span>
        <h2 class="text-2xl font-bold">Your cart is empty</h2>
        <p class="text-gray-500">Add some delicious items from our menu!</p>
        <a href="/" class="mt-2 rounded-lg bg-orange-600 px-6 py-3 font-semibold text-white hover:opacity-90">
            Browse menu
        </a>
    </div>
}
else
{
    <div class="mx-auto max-w-4xl px-4 py-8">
        <h1 class="mb-6 text-3xl font-bold">Your cart</h1>

        <div class="flex flex-col gap-6 lg:flex-row">

            <!-- Line items -->
            <div class="flex flex-1 flex-col gap-3">
                @foreach (var cartItem in Cart.Items)
                {
                    var item = cartItem.Item;
                    <div class="flex overflow-hidden rounded-xl border bg-white shadow-sm">
                        <img src="@item.ImageUrl" alt="@item.Name"
                             class="h-24 w-24 shrink-0 object-cover"
                             onerror="this.src='https://placehold.co/96?text=🍔'" />
                        <div class="flex flex-1 flex-col justify-center gap-1 py-3 px-4">
                            <div class="flex items-start justify-between gap-2">
                                <span class="font-semibold">@item.Name</span>
                                <button @onclick="() => Cart.RemoveItem(item.Id)"
                                        class="text-gray-400 transition-colors hover:text-red-500">
                                    🗑️
                                </button>
                            </div>
                            <span class="text-sm text-gray-500">@item.Price.ToString("C") each</span>
                            <div class="mt-1 flex items-center gap-3">
                                <button @onclick="() => Cart.SetQuantity(item.Id, cartItem.Quantity - 1)"
                                        class="flex h-7 w-7 items-center justify-center rounded-full border bg-white text-gray-700 hover:bg-gray-50">
                                    −
                                </button>
                                <span class="w-4 text-center font-medium">@cartItem.Quantity</span>
                                <button @onclick="() => Cart.SetQuantity(item.Id, cartItem.Quantity + 1)"
                                        class="flex h-7 w-7 items-center justify-center rounded-full bg-orange-600 text-white hover:opacity-90">
                                    +
                                </button>
                                <span class="ml-auto font-semibold text-orange-600">
                                    @((item.Price * cartItem.Quantity).ToString("C"))
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary -->
            <div class="w-full lg:w-80">
                <div class="sticky top-20 rounded-xl border bg-white p-5 shadow-sm">
                    <h2 class="mb-4 text-lg font-semibold">Order summary</h2>
                    <hr class="mb-3" />
                    <div class="mb-2 flex justify-between text-sm">
                        <span class="text-gray-500">Subtotal</span>
                        <span>@Cart.Subtotal.ToString("C")</span>
                    </div>
                    <div class="mb-2 flex justify-between text-sm">
                        <span class="text-gray-500">Delivery fee</span>
                        @if (DeliveryFee == 0)
                        {
                            <span class="font-medium text-orange-600">Free 🎉</span>
                        }
                        else
                        {
                            <span>@DeliveryFee.ToString("C")</span>
                        }
                    </div>
                    @if (DeliveryFee > 0)
                    {
                        <div class="mb-3 rounded-lg bg-orange-50 px-3 py-2 text-xs text-orange-700">
                            Add @((25m - Cart.Subtotal).ToString("C")) more for free delivery!
                        </div>
                    }
                    <hr class="mb-3" />
                    <div class="mb-4 flex justify-between font-semibold">
                        <span>Total</span>
                        <span class="text-orange-600">@Total.ToString("C")</span>
                    </div>
                    <button @onclick="Checkout"
                            class="w-full rounded-lg bg-orange-600 py-3 text-sm font-semibold text-white hover:opacity-90">
                        @(Auth.IsAuthenticated ? "Proceed to checkout →" : "Sign in to checkout")
                    </button>
                    <a href="/"
                       class="mt-2 block w-full rounded-lg border border-gray-200 py-2.5 text-center text-sm font-medium hover:bg-gray-50">
                        Continue shopping
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const decimal FreeDeliveryThreshold = 25m;
    private const decimal DeliveryFeeAmount = 2.99m;

    private decimal DeliveryFee => Cart.Subtotal >= FreeDeliveryThreshold ? 0m : DeliveryFeeAmount;
    private decimal Total => Cart.Subtotal + DeliveryFee;

    protected override void OnInitialized() => Cart.OnChange += StateHasChanged;

    private void Checkout()
    {
        Nav.NavigateTo(Auth.IsAuthenticated ? "/checkout" : "/login?ReturnUrl=/checkout");
    }

    public void Dispose() => Cart.OnChange -= StateHasChanged;
}
