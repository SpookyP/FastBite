@inherits LayoutComponentBase

<!-- Tailwind CSS via CDN — replace with a build step for production -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        theme: {
            extend: {
                fontFamily: {
                    sans: ['Inter', 'ui-sans-serif', 'system-ui'],
                    display: ['Poppins', 'ui-sans-serif'],
                }
            }
        }
    }
</script>

<div class="flex min-h-screen flex-col bg-orange-50">
    <Navbar />
    <main class="flex-1">
        @Body
    </main>
    <footer class="border-t bg-white py-6 text-center text-sm text-gray-400">
        © @DateTime.Now.Year FastBite — Good food, fast delivery.
    </footer>
</div>
