@using FastBite.Models
@using FastBite.Services
@inject CartState Cart

<div class="group overflow-hidden rounded-xl border bg-white shadow-sm transition-shadow hover:shadow-lg flex flex-col">
    <div class="relative h-44 w-full overflow-hidden">
        <img src="@Item.ImageUrl"
             alt="@Item.Name"
             class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
             onerror="this.src='https://placehold.co/400x300?text=FastBite'" />
        @if (Item.Popular)
        {
            <span class="absolute left-3 top-3 rounded-full bg-orange-600 px-2 py-0.5 text-xs font-medium text-white">
                🔥 Popular
            </span>
        }
    </div>

    <div class="flex flex-1 flex-col gap-2 p-4">
        <div class="flex items-start justify-between gap-2">
            <h3 class="font-semibold leading-tight">@Item.Name</h3>
            <span class="whitespace-nowrap font-semibold text-orange-600">@Item.Price.ToString("C")</span>
        </div>
        <p class="text-sm text-gray-500 line-clamp-2">@Item.Description</p>
        <div class="flex items-center gap-3 text-sm text-gray-400">
            <span>⭐ @Item.Rating.ToString("F1")</span>
            <span>🕐 @Item.PrepMinutes min</span>
        </div>
        <button @onclick="AddToCart"
                class="mt-auto w-full rounded-lg bg-orange-600 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90 active:opacity-80">
            + Add to cart
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public MenuItem Item { get; set; } = default!;

    private void AddToCart()
    {
        Cart.AddItem(Item);
    }
}
